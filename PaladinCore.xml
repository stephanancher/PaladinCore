<Ui xmlns="http://www.blizzard.com/wow/ui/">
    <Button name="PCAMinimapButton" parent="Minimap" enableMouse="true" hidden="true" frameStrata="MEDIUM">
        <Size><AbsDimension x="33" y="33"/></Size>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture name="PCAMinimapButtonIcon" file="Interface\Icons\Ability_ThunderBolt">
                    <Size><AbsDimension x="21" y="21"/></Size>
                    <Anchors>
                        <Anchor point="TOPLEFT">
                            <Offset><AbsDimension x="7" y="-6"/></Offset>
                        </Anchor>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <Texture file="Interface\Minimap\MiniMap-TrackingBorder">
                    <Size><AbsDimension x="56" y="56"/></Size>
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <Frames>
            <Frame name="PCAMinimapButtonDraggingFrame" hidden="true">
                <Scripts>
                    <OnUpdate>
                        PCA_MinimapButton_OnUpdate()
                    </OnUpdate>
                </Scripts>
            </Frame>
        </Frames>
        <HighlightTexture alphaMode="ADD" file="Interface\Minimap\UI-Minimap-ZoomButton-Highlight"/>
        <Scripts>
            <OnLoad>
                this:RegisterForClicks("LeftButtonUp", "RightButtonUp")
                this:RegisterForDrag("LeftButton")
                PCA_MinimapButton_UpdatePosition()
            </OnLoad>
            <OnDragStart>
                PCAMinimapButtonDraggingFrame:Show()
            </OnDragStart>
            <OnDragStop>
                PCAMinimapButtonDraggingFrame:Hide()
            </OnDragStop>
            <OnClick>
                if PCAFrame:IsVisible() then
                    PCAFrame:Hide()
                else
                    PCA_OpenMenu()
                end
            </OnClick>
            <OnEnter>
                GameTooltip:SetOwner(this, "ANCHOR_LEFT")
                GameTooltip:AddLine("PaladinCore", 1, 1, 0)
                GameTooltip:AddLine("Left-Click: Open settings", 1, 1, 1)
                GameTooltip:AddLine("Drag to move", 0.7, 0.7, 0.7)
                GameTooltip:Show()
            </OnEnter>
            <OnLeave>
                GameTooltip:Hide()
            </OnLeave>
        </Scripts>
    </Button>

    <Frame name="PCAFrame" hidden="true" movable="true" enableMouse="true">
        <Size><AbsDimension x="330" y="500"/></Size>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>
        <Backdrop bgFile="Interface\\Buttons\\UI-SliderBar-Background"
                  edgeFile="Interface\\Tooltips\\UI-Tooltip-Border"
                  tile="true">
            <BackgroundInsets><AbsInset left="4" right="4" top="4" bottom="4"/></BackgroundInsets>
            <TileSize><AbsValue val="16"/></TileSize>
            <EdgeSize><AbsValue val="16"/></EdgeSize>
        </Backdrop>
        <Layers>
            <Layer level="BACKGROUND">
                <!-- Outer dark layer -->
                <Texture name="$parentBg">
                    <Anchors><Anchor point="TOPLEFT"/><Anchor point="BOTTOMRIGHT"/></Anchors>
                    <Color r="0" g="0" b="0" a="0.9"/>
                </Texture>
            </Layer>
            <Layer level="BORDER">
                <!-- Header bar area -->
                <Texture name="$parentHeaderBg">
                    <Size><AbsDimension y="55"/></Size>
                    <Anchors><Anchor point="TOPLEFT"/><Anchor point="TOPRIGHT"/></Anchors>
                    <Color r="0.1" g="0.1" b="0.1" a="1"/>
                </Texture>
                <Texture name="$parentContentBorder">
                   <Anchors>
                        <Anchor point="TOPLEFT" x="8" y="-55"/>
                        <Anchor point="BOTTOMRIGHT" x="-8" y="8"/>
                    </Anchors>
                    <Color r="0.05" g="0.05" b="0.05" a="1"/>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <FontString name="PCATitle" inherits="GameFontNormalGroup" font="Fonts\\FRIZQT__.TTF" fontHeight="16">
                    <Anchors>
                        <Anchor point="TOP" y="-12"/>
                    </Anchors>
                    <Text>PALADIN CORE</Text>
                    <Color r="1" g="1" b="1"/>
                </FontString>
                <FontString name="PCASubTitle" inherits="GameFontNormalSmall" font="Fonts\\FRIZQT__.TTF" fontHeight="12">
                    <Anchors>
                        <Anchor point="TOP" y="-28"/>
                    </Anchors>
                    <Text>ROTATION &amp; UTILITY</Text>
                    <Color r="0.6" g="0.6" b="0.6"/>
                </FontString>
                <Texture name="$parentHeaderLine">
                    <Size><AbsDimension x="314" y="1"/></Size>
                    <Anchors><Anchor point="TOP" y="-54"/></Anchors>
                    <Color r="1" g="0.82" b="0" a="0.5"/>
                </Texture>
            </Layer>
        </Layers>
        <Scripts>
            <OnLoad>
                this:RegisterForDrag("LeftButton")
                PCA_OnLoad()
            </OnLoad>
            <OnDragStart>
                this:StartMoving()
            </OnDragStart>
            <OnDragStop>
                this:StopMovingOrSizing()
            </OnDragStop>
        </Scripts>
    </Frame>
</Ui>
